
{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ACI Model",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tenants": {
      "type": "array",
      "items": { "$ref": "#/$defs/tenant" }
    },
    "fabric": { "$ref": "#/$defs/fabric" },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/node" }
    }
  },
  "required": ["tenants"],
  "$defs": {
    "state": {
      "type": "string",
      "enum": ["present", "absent"]
    },

    "tenant": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "vrfs": { "type": "array", "items": { "$ref": "#/$defs/vrf" } },
        "bridge_domains": { "type": "array", "items": { "$ref": "#/$defs/bridge_domain" } },
        "contracts": { "type": "array", "items": { "$ref": "#/$defs/contract" } },
        "filters": { "type": "array", "items": { "$ref": "#/$defs/filter" } },
        "application_profiles": { "type": "array", "items": { "$ref": "#/$defs/app_profile" } },
        "l3outs": { "type": "array", "items": { "$ref": "#/$defs/l3out" } },
        "policies": { "$ref": "#/$defs/policies" }
      },
      "required": ["name"]
    },

    "policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "match_rules": { "type": "array", "items": { "$ref": "#/$defs/match_rule" } },
        "set_rules": { "type": "array", "items": { "$ref": "#/$defs/set_rule" } },
        "route_maps": { "type": "array", "items": { "$ref": "#/$defs/route_map" } },
        "mcast_route_maps": { "type": "array", "items": { "$ref": "#/$defs/mcast_route_map" } }
      }
    },

    "fabric": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "leaf_intf_profiles": { "type": "array", "items": { "$ref": "#/$defs/leaf_intf_profile" } },
        "leaf_profiles": { "type": "array", "items": { "$ref": "#/$defs/leaf_profile" } },
        "vlan_pools": { "type": "array", "items": { "$ref": "#/$defs/vlan_pool" } },
        "domains": { "$ref": "#/$defs/domains" },
        "aaeps": { "type": "array", "items": { "$ref": "#/$defs/aaep" } },
        "intf_policies": { "$ref": "#/$defs/intf_policies" },
        "interface_policy_groups": { "$ref": "#/$defs/interface_policy_groups" }
      }
    },

    "leaf_intf_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name"]
    },

    "leaf_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "leaf_blocks": { "type": "array", "items": { "$ref": "#/$defs/leaf_block" } },
        "leaf_interface_profiles": { "type": "array", "items": { "$ref": "#/$defs/leaf_interface_profile_ref" } }
      },
      "required": ["name"]
    },

    "leaf_block": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": { "type": "integer" },
        "to": { "type": "integer" },
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["from", "to"]
    },

    "leaf_interface_profile_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name"]
    },

    "vlan_pool": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "allocation_mode": { "type": "string", "enum": ["static", "dynamic"] },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "ranges": { "type": "array", "items": { "$ref": "#/$defs/vlan_range" } }
      },
      "required": ["name"]
    },

    "vlan_range": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from_": { "type": "integer" },
        "to_": { "type": "integer" },
        "description": { "type": "string" },
        "role": { "type": "string", "enum": ["external", "internal"] },
        "allocation_mode": { "type": "string", "enum": ["inherit", "static", "dynamic"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["from_", "to_"]
    },

    "domains": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "physical": { "type": "array", "items": { "$ref": "#/$defs/domain_ref" } },
        "l3_external": { "type": "array", "items": { "$ref": "#/$defs/domain_ref" } }
      }
    },

    "domain_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "vlan_pool": {
          "anyOf": [
            { "type": "string" },
            { "$ref": "#/$defs/vlan_pool_ref" }
          ]
        }
      },
      "required": ["name"]
    },

    "vlan_pool_ref": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "allocation_mode": { "type": "string", "enum": ["static", "dynamic"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name"]
    },

    "aaep": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "domains": { "type": "array", "items": { "$ref": "#/$defs/aaep_domain_binding" } },
        "epgs": { "type": "array", "items": { "$ref": "#/$defs/aaep_epg_binding" } }
      },
      "required": ["name"]
    },

    "aaep_epg_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tenant": { "type": "string" },
        "application_profile": { "type": "string" },
        "epg": { "type": "string" },
        "vlan": { "type": "integer" },
        "mode": { "type": "string", "enum": ["regular", "untagged", "native"] },
        "deployment": { "type": "string", "enum": ["immediate", "lazy"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["tenant", "application_profile", "epg", "vlan"]
    },

    "aaep_domain_binding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["physical", "l3_external"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name", "type"]
    },

    "intf_policies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lldp": { "type": "array", "items": { "$ref": "#/$defs/lldp_policy" } },
        "cdp": { "type": "array", "items": { "$ref": "#/$defs/cdp_policy" } },
        "mcp": { "type": "array", "items": { "$ref": "#/$defs/mcp_policy" } },
        "lag": { "type": "array", "items": { "$ref": "#/$defs/lag_policy" } },
        "link_layer": { "type": "array", "items": { "$ref": "#/$defs/ll_policy" } }
      }
    },

    "ll_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "auto_negotiation": { "type": "boolean" },
        "speed": { "type": "string", "enum": ["100M", "1G", "10G", "25G", "40G", "400G", "auto", "inherit"] },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } }
      },
      "required": ["name", "auto_negotiation", "speed"]
    },

    "lldp_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "receive": { "type": "string", "enum": ["enabled", "disabled"] },
        "transmit": { "type": "string", "enum": ["enabled", "disabled"] },
        "DCBXP_version": { "type": "string", "enum": ["IEEE", "CEE"] },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } }
      },
      "required": ["name", "receive", "transmit"]
    },

    "cdp_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "admin_state": { "type": "string", "enum": ["enabled", "disabled"] },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } }
      },
      "required": ["name", "admin_state"]
    },

    "mcp_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "admin_state": { "type": "string", "enum": ["enabled", "disabled"] },
        "MCP_per_VLAN": { "type": "string", "enum": ["on", "off"] },
        "mcp_mode": { "type": "string", "enum": ["strict", "non-strict"] },
        "max_number_of_vlan": { "type": "integer" },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } }
      },
      "required": ["name", "admin_state"]
    },

    "lag_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "min": { "type": "integer" },
        "max": { "type": "integer" },
        "mode": { "type": "string", "enum": ["active", "off"] },
        "fast_select_hot_standby_ports": { "type": "boolean" },
        "graceful_convergence": { "type": "boolean" },
        "suspend_individual_port": { "type": "boolean" },
        "symmetric_hashing": { "type": "boolean" },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } }
      },
      "required": ["name", "mode"]
    },

    "interface_policy_groups": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "access": { "type": "array", "items": { "$ref": "#/$defs/intf_policy_group" } },
        "port-channel": { "type": "array", "items": { "$ref": "#/$defs/intf_policy_group" } },
        "vpc": { "type": "array", "items": { "$ref": "#/$defs/intf_policy_group" } }
      }
    },

    "intf_policy_group": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "lldp": { "type": "string" },
        "cdp": { "type": "string" },
        "mcp": { "type": "string" },
        "stp": { "type": "string" },
        "l2": { "type": "string" },
        "ll": { "type": "string" },
        "lag": { "type": "string" },
        "aaep": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } }
      },
      "required": ["name"]
    },

    "node": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["leaf", "spine"] },
        "id": { "type": "integer" },
        "sn": { "type": "string" },
        "intf_profile": { "type": "string" },
        "vpc_intf_profile": { "type": "string" },
        "interfaces": { "type": "array", "items": { "$ref": "#/$defs/node_interface" } }
      },
      "required": ["name", "type", "id", "sn", "intf_profile"]
    },

    "node_interface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "port": { "type": "integer" },
        "card": { "type": "integer" },
        "intf_pol_group": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["port", "card", "intf_pol_group"]
    },

    "tag": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name", "value"]
    },

    "vrf": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "enforcement": { "type": "string", "enum": ["enforced", "unenforced"] },
        "preferred_group": { "type": "string", "enum": ["enabled", "disabled"] },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "contracts": { "type": "array", "items": { "$ref": "#/$defs/vrf_contract" } },
        "ipv4_route_targets": { "type": "array", "items": { "$ref": "#/$defs/route_target" } },
        "ipv6_route_targets": { "type": "array", "items": { "$ref": "#/$defs/route_target" } },
        "PIM": { "$ref": "#/$defs/vrf_pim" }
      },
      "required": ["name"]
    },

    "vrf_pim": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": { "$ref": "#/$defs/state" },
        "mtu": { "type": "integer" },
        "fast-convergenace": { "type": "boolean" },
        "strict-RFC-compilant": { "type": "boolean" },
        "static_rp": { "type": "array", "items": { "$ref": "#/$defs/vrf_pim_static_rp" } }
      }
    },

    "vrf_pim_static_rp": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ip": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "route_map": {
          "anyOf": [
            { "type": "string" },
            { "$ref": "#/$defs/vrf_pim_static_rp_route_map" }
          ]
        }
      },
      "required": ["ip"]
    },

    "vrf_pim_static_rp_route_map": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "tenant": { "type": "string" }
      },
      "required": ["name", "tenant"]
    },

    "vrf_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["provider", "consumer"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name", "type"]
    },

    "route_target": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["import", "export"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name", "type"]
    },

    "bridge_domain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "vrf": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "unicast_routing": { "type": "boolean" },
        "endpoint_move_detection": { "type": "string", "enum": ["", "garp"] },
        "l2_unknown_unicast": { "type": "string", "enum": ["proxy", "flood"] },
        "l3_unknown_multicast": { "type": "string", "enum": ["opt-flood", "flood"] },
        "arp_flood": { "type": "boolean" },
        "PIM": { "type": "boolean" },
        "subnets": { "type": "array", "items": { "$ref": "#/$defs/subnet" } },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "l3outs": { "type": "array", "items": { "$ref": "#/$defs/bd_l3out" } },
        "dhcp_relay_labels": { "type": "array", "items": { "$ref": "#/$defs/dhcp_relay_label" } }
      },
      "required": ["name", "vrf"]
    },

    "subnet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ip": { "type": "string" },
        "scope": { "type": "string", "enum": ["public", "private"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["ip"]
    },

    "bd_l3out": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name"]
    },

    "contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "scope": { "type": "string", "enum": ["context", "tenant", "global"] },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "subjects": { "type": "array", "items": { "$ref": "#/$defs/subject" } }
      },
      "required": ["name"]
    },

    "subject": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "reverse_filter_port": { "type": "string" },
        "filters": { "type": "array", "items": { "$ref": "#/$defs/subject_filter" } }
      },
      "required": ["name"]
    },

    "subject_filter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "action": { "type": "string", "enum": ["permit", "deny"] },
        "log": { "type": "boolean" },
        "policy_compression": { "type": "boolean" }
      },
      "required": ["name"]
    },

    "filter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "entries": { "type": "array", "items": { "$ref": "#/$defs/filter_entry" } }
      },
      "required": ["name"]
    },

    "filter_entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "ethertype": {
          "type": "string",
          "enum": ["unspecified", "arp", "fcoe", "ip", "ipv4", "ipv6", "mac_security", "mpls_ucast", "trill"]
        },
        "ip_protocol": {
          "anyOf": [
            {
              "type": "string",
              "enum": ["unspecified", "icmp", "icmpv6", "igmp", "tcp", "udp", "eigrp", "egp", "igp", "ospfigp", "pim", "l2tp"]
            },
            { "type": "string", "pattern": "^[0-9]+$" }
          ]
        },
        "from_port": {
          "anyOf": [
            { "type": "integer", "minimum": 0, "maximum": 65535 },
            { "type": "string", "enum": ["unspecified", "dns", "ftpData", "http", "https", "pop3", "rtsp", "smtp"] }
          ]
        },
        "to_port": {
          "anyOf": [
            { "type": "integer", "minimum": 0, "maximum": 65535 },
            { "type": "string", "enum": ["unspecified", "dns", "ftpData", "http", "https", "pop3", "rtsp", "smtp"] }
          ]
        }
      },
      "required": ["name"]
    },

    "match_rule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "prefixes": { "type": "array", "items": { "$ref": "#/$defs/match_rule_prefix" } }
      },
      "required": ["name"]
    },

    "match_rule_prefix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ip": { "type": "string" },
        "description": { "type": "string" },
        "aggregate": { "type": "boolean" },
        "greater_equal_mask": { "type": "integer" },
        "less_equal_mask": { "type": "integer" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["ip"]
    },

    "set_rule": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "as_path": { "type": "array", "items": { "$ref": "#/$defs/set_rule_as_path" } }
      },
      "required": ["name"]
    },

    "set_rule_as_path": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "order": { "type": "integer" },
        "asn": { "type": "integer" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["order", "asn"]
    },

    "route_map": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "contexts": { "type": "array", "items": { "$ref": "#/$defs/route_map_context" } }
      },
      "required": ["name"]
    },

    "route_map_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "order": { "type": "integer" },
        "action": { "type": "string", "enum": ["permit", "deny"] },
        "description": { "type": "string" },
        "match_rule": { "type": "string" },
        "set_rule": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name", "order", "action"]
    },

    "mcast_route_map": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "entries": { "type": "array", "items": { "$ref": "#/$defs/mcast_route_map_entry" } }
      },
      "required": ["name"]
    },

    "mcast_route_map_entry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "order": { "type": "integer" },
        "group": { "type": "string", "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/[0-9]{1,2}$" },
        "rp": { "type": "string", "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}/32$" },
        "source": { "type": "string", "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}(/[0-9]{1,2})?$" },
        "action": { "type": "string", "enum": ["permit", "deny"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["order", "group", "rp", "action"]
    },

    "app_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "epgs": { "type": "array", "items": { "$ref": "#/$defs/epg" } },
        "esgs": { "type": "array", "items": { "$ref": "#/$defs/esg" } }
      },
      "required": ["name"]
    },

    "esg": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "preferred_group_member": { "type": "string", "enum": ["include", "exclude"] },
        "vrf": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "epgs": { "type": "array", "items": { "$ref": "#/$defs/esg_epg_selector" } },
        "contracts": { "type": "array", "items": { "$ref": "#/$defs/vrf_contract" } }
      },
      "required": ["name", "vrf"]
    },

    "esg_epg_selector": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name"]
    },

    "epg": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "bd": { "type": "string" },
        "preferred_group_member": { "type": "string", "enum": ["include", "exclude"] },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "domains": { "type": "array", "items": { "$ref": "#/$defs/domain" } },
        "interfaces": { "type": "array", "items": { "$ref": "#/$defs/interface" } },
        "contracts": { "type": "array", "items": { "$ref": "#/$defs/vrf_contract" } }
      },
      "required": ["name", "bd"]
    },

    "dhcp_relay_label": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "scope": { "type": "string", "enum": ["infra", "tenant"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name"]
    },

    "domain": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["physical", "virtual"] },
        "resolution": { "type": "string", "enum": ["immediate", "lazy", "pre-provision"] },
        "deployment": { "type": "string", "enum": ["immediate", "lazy"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name", "type"]
    },

    "interface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "leaf_id": { "type": "integer" },
        "pod": { "type": "integer" },
        "port": { "type": "string" },
        "ipg": { "type": "string" },
        "peer_leaf_id": { "type": "integer" },
        "mode": { "type": "string", "enum": ["regular", "untagged"] },
        "vlan": { "type": "integer" },
        "deployment": { "type": "string", "enum": ["immediate", "lazy"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["leaf_id", "pod", "mode", "vlan"]
    },

    "l3out": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "vrf": { "type": "string" },
        "domain": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "import_route_control": { "type": "boolean" },
        "export_route_control": { "type": "boolean" },
        "protocols": { "$ref": "#/$defs/l3out_protocols" },
        "PIM": { "type": "boolean" },
        "external_epgs": { "type": "array", "items": { "$ref": "#/$defs/external_epg" } },
        "node_profiles": { "type": "array", "items": { "$ref": "#/$defs/node_profile" } }
      },
      "required": ["name", "vrf", "domain"]
    },

    "l3out_protocols": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ospf": { "$ref": "#/$defs/ospf_policy" },
        "bgp": { "anyOf": [{ "type": "null" }, { "$ref": "#/$defs/bgp_policy" }] }
      }
    },

    "bgp_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "state": { "$ref": "#/$defs/state" }
      }
    },

    "ospf_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "area_id": {
          "type": "string",
          "anyOf": [
            { "const": "backbone" },
            { "pattern": "^([0-9]{1,3}\\.){3}[0-9]{1,3}$" },
            { "pattern": "^[0-9]+$" }
          ]
        },
        "area_type": { "type": "string", "enum": ["regular", "stub", "nssa"] },
        "area_cost": { "type": "integer" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["area_id"]
    },

    "external_epg": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "preferred_group_member": { "type": "string", "enum": ["include", "exclude"] },
        "tags": { "type": "array", "items": { "$ref": "#/$defs/tag" } },
        "subnets": { "type": "array", "items": { "$ref": "#/$defs/external_subnet" } },
        "contracts": { "type": "array", "items": { "$ref": "#/$defs/vrf_contract" } }
      },
      "required": ["name"]
    },

    "external_subnet": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ip": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "description": { "type": "string" },
        "agg_export": { "type": "boolean" },
        "agg_inport": { "type": "boolean" },
        "agg_shared": { "type": "boolean" },
        "export_route_ctrl": { "type": "boolean" },
        "external_epg": { "type": "boolean" },
        "shared_route_ctrl": { "type": "boolean" },
        "shared_security_import": { "type": "boolean" }
      },
      "required": ["ip"]
    },

    "node_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "routers": { "type": "array", "items": { "$ref": "#/$defs/router" } },
        "static_routes": { "type": "array", "items": { "$ref": "#/$defs/static_route" } },
        "interface_profiles": { "type": "array", "items": { "$ref": "#/$defs/interface_profile" } }
      },
      "required": ["name"]
    },

    "router": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pod": { "type": "integer" },
        "leaf_id": { "type": "integer" },
        "router_id": { "type": "string" },
        "loopback": { "type": "boolean" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["pod", "leaf_id", "router_id"]
    },

    "static_route": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "prefix": { "type": "string" },
        "nhop": { "type": "string" },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["prefix", "nhop"]
    },

    "interface_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "state": { "$ref": "#/$defs/state" },
        "interfaces": { "$ref": "#/$defs/l3_interfaces_by_type" }
      },
      "required": ["name"]
    },

    "l3_interfaces_by_type": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "svi": { "type": "array", "items": { "allOf": [{ "$ref": "#/$defs/l3_interface" }, { "required": ["vlan", "mode"] }] } },
        "sub-interface": { "type": "array", "items": { "allOf": [{ "$ref": "#/$defs/l3_interface" }, { "required": ["vlan"] }] } },
        "l3-port": { "type": "array", "items": { "$ref": "#/$defs/l3_interface" } }
      }
    },

    "l3_interface": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pod": { "type": "integer" },
        "leaf_id": { "type": "integer" },
        "port": { "type": "string" },
        "ipg": { "type": "string" },
        "peer_leaf_id": { "type": "integer" },
        "mode": { "type": "string", "enum": ["regular", "untagged", "native"] },
        "vlan": { "type": "integer" },
        "addr": { "type": "string" },
        "peer_addr": { "type": "string" },
        "mtu": {
          "anyOf": [
            { "type": "string", "const": "inherit" },
            { "type": "integer", "minimum": 576, "maximum": 9216 }
          ]
        },
        "state": { "$ref": "#/$defs/state" },
        "connectivity_profiles": { "type": "array", "items": { "$ref": "#/$defs/bgp_connectivity_profile" } }
      },
      "required": ["pod", "leaf_id", "addr"]
    },

    "bgp_connectivity_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "peer_address": { "type": "string" },
        "description": { "type": "string" },
        "remote_asn": { "type": "integer" },
        "local_asn": { "type": "integer" },
        "send_community": { "type": "boolean" },
        "send_extended_community": { "type": "boolean" },
        "bfd": { "type": "boolean" },
        "weight": { "type": "integer" },
        "ttl": { "type": "integer" },
        "state": { "$ref": "#/$defs/state" },
        "route_maps": { "type": "array", "items": { "$ref": "#/$defs/bgp_peer_route_map" } }
      },
      "required": ["peer_address", "remote_asn"]
    },

    "bgp_peer_route_map": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "direction": { "type": "string", "enum": ["import", "export"] },
        "state": { "$ref": "#/$defs/state" }
      },
      "required": ["name", "direction"]
    }
  }
}