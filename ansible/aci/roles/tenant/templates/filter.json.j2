{
  "vzFilter": {
    "attributes": {
      "name": "{{ filter_name }}",
      "status": "{{ 'deleted' if filter.state is defined and filter.state == 'absent' else 'created,modified' }}"
      {% if filter.state | default('present') != 'absent' %}
      ,
      "descr": "{{ filter.description | default(filter_default_description) }}"
      {% endif %}
    }
    {% if filter.state | default('present') != 'absent' %}
    ,
    "children": [
      {% for tag in filter.tags | default( [] ) %}
      {
        "tagAnnotation": {
          "attributes": {
            "key": "{{ tag.name }}",
            "value": "{{ tag.value }}",
            "status": "{{ 'deleted' if tag.state is defined and tag.state == 'absent' else 'created,modified' }}"
          }
        }
      }
      {% if not loop.last %},{% endif %}
      {% endfor %}

      {% if filter.tags|default([])| length > 0 and filter.entries|default([])| length > 0 %},{% endif %}

      {% for entry in filter.entries | default( [] ) %}
      {
        "vzEntry": {
          "attributes": {
            "name": "{{ entry_name_prefix ~ entry.name ~ entry_name_suffix}}",
            "status": "{{ 'deleted' if entry.state is defined and entry.state == 'absent' else 'created,modified' }}"
            {% if entry.state|default('present') != 'absent' %}
            ,
            "descr": "{{ entry.description | default(entry_default_description) }}",
            "etherT": "{{ entry.ethertype | default(entry_default_ethertype) }}",
            "prot": "{{ entry.ip_protocol | default(entry_default_ip_protocol) }}",
            "dFromPort": "{{ entry.from_port | default(entry_default_from_port) }}",
            "dToPort": "{{ entry.to_port | default(entry_default_to_port) }}"
            {% endif %}
          }
        }
      }
      {% if not loop.last %},{% endif %}
      {% endfor %}
    ]
    {% endif %}
  }
}