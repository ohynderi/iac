{
  "fvAEPg": {
    "attributes": {
      "name": "{{ epg_name }}",
      "status": "{{ 'deleted' if epg.state is defined and epg.state == 'absent' else 'created,modified' }}",
      "descr": "{{ epg.description | default(epg_default_description) }}",
      "prefGrMemb": "{{ epg.preferred_group_member | default(epg_default_preferred_group_member) }}"
    }
    {% if epg.state | default('present') != 'absent' %}
    ,
    "children": [
      {
        "fvRsBd": {
          "attributes": {
            "tnFvBDName": "{{ epg.bd }}",
            "status": "created,modified"
          }
        }
      }

      {% for tag in epg.tags | default( [] ) %}
      ,
      {
        "tagAnnotation": {
          "attributes": {
            "key": "{{ tag.name }}",
            "value": "{{ tag.value }}",
            "status": "{{ 'deleted' if tag.state is defined and tag.state == 'absent' else 'created,modified' }}"
          }
        }
      }
      {% endfor %}

      {% for domain in epg.domains | default( [] ) %}
      ,
      {
        "fvRsDomAtt": {
          "attributes": {
            {% if ( domain.type | lower ) == 'physical' %}
            "tDn": "uni/phys-{{ domain.name }}",
            {% elif ( domain.type | lower ) == 'virtual' %}
            "tDn": "uni/vmmp-VMware/dom-{{ domain.name }}",
            "resImedcy": "{{ domain.resolution | default(domain_immediacy) }}",
            "instrImedcy": "{{ domain.deployment | default(domain_deployment) }}",
            {% endif %}

            "status": "{{ 'deleted' if domain.state is defined and domain.state == 'absent' else 'created,modified' }}"
          }
        }
      }
      {% endfor %}

      {% for intf in epg.interfaces | default( [] ) %}
      ,
      {
        "fvRsPathAtt": {
          "attributes": {
            "instrImedcy": "{{ intf.deployment | default(interface_deployment) }}",
            "encap": "vlan-{{ intf.vlan }}",
            "mode": "{{ intf.mode }}",

            {% if intf.port is defined and intf.leaf_id is defined %}
            "tDn": "topology/pod-{{ intf.pod }}/paths-{{ intf.leaf_id }}/pathep-[{{ intf.port | lower }}]",
            {% elif intf.ipg is defined and intf.leaf_id is defined and intf.peer_leaf_id is defined %}
            "tDn": "topology/pod-{{ intf.pod }}/protpaths-{{ intf.leaf_id }}-{{ intf.peer_leaf_id }}/pathep-[{{ intf.ipg }}]",
            {% elif intf.ipg is defined and intf.leaf_id is defined %}
            "tDn": "topology/pod-{{ intf.pod }}/paths-{{ intf.leaf_id }}/pathep-[{{ intf.ipg }}]",
            {% endif %}

            "status": "{{ 'deleted' if intf.state is defined and intf.state == 'absent' else 'created,modified' }}"
          }
        }
      }
      {% endfor %}

      {% for contract in epg.contracts | default( [] ) %}
      {% if contract.type == 'consumer' %}
      ,
      {
        "fvRsCons": {
          "attributes": {
            "tnVzBrCPName": "{{ contract.name }}",
            "status": "{{ 'deleted' if contract.state is defined and contract.state == 'absent' else 'created,modified' }}"
          }
        }
      }
      {% else %}
      ,
      {
        "fvRsProv": {
          "attributes": {
            "tnVzBrCPName": "{{ contract.name }}",
            "status": "{{ 'deleted' if contract.state is defined and contract.state == 'absent' else 'created,modified' }}"
          }
        }
      }
      {% endif %}
      {% endfor %}

    ]
    {% endif %}
  }
}