{#- Copy of roles/node/templates/intf_selector.json.j2 - identical, keep both in sync -#}
{
  "infraHPortS": {
    "attributes": {
      "name": "{{ intf_name }}",
      "status": "{{ 'deleted' if intf.state is defined and intf.state == 'absent' else 'created,modified' }}"
      {% if intf.state | default('present') != 'absent' %}
      ,
      "descr": "{{ intf.selector_description | default(intf_default_selector_description) }}"
      {% endif %}
    }
    {% if intf.state | default('present') != 'absent' %}
    ,
    "children": [
      {
        "infraPortBlk": {
          "attributes": {
            "name": "{{ intf.port_block_name | default(intf_default_port_block_name) }}",
            "descr": "{{ intf.port_block_description | default(intf_default_port_block_description) }}",
            "fromCard": "{{ intf.card }}",
            "toCard": "{{ intf.card }}",
            "fromPort": "{{ intf_from_port }}",
            "toPort": "{{ intf_to_port }}",
            "status": "{{ 'deleted' if intf.state is defined and intf.state == 'absent' else 'created,modified' }}"
          }
        }
      },
      {
        "infraRsAccBaseGrp": {
          "attributes": {
            "tDn": "uni/infra/funcprof/{{ ipg_type }}-{{ intf.intf_pol_group }}",
            "status": "{{ 'deleted' if intf.state is defined and intf.state == 'absent' else 'created,modified' }}"
          }
        }
      }

      {% if intf.tags|default([])| length > 0 %},{% endif %}

      {% for tag in intf.tags | default( [] ) %}
      {
        "tagAnnotation": {
          "attributes": {
            "key": "{{ tag.name }}",
            "value": "{{ tag.value }}",
            "status": "{{ 'deleted' if tag.state is defined and tag.state == 'absent' else 'created,modified' }}"
          }
        }
      }
      {% if not loop.last %},{% endif %}
      {% endfor %}

    ]
    {% endif %}
  }
}
